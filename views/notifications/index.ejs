<%
const nIconMap = {
  ticket_created:   { icon:'fa-ticket-alt',  color:'bg-primary',   label:'Tiket Baru'  },
  ticket_assigned:  { icon:'fa-user-check',  color:'bg-warning',   label:'Penugasan'   },
  comment_added:    { icon:'fa-comment',     color:'bg-info',      label:'Komentar'    },
  status_changed:   { icon:'fa-sync-alt',    color:'bg-success',   label:'Status'      },
  attachment_added: { icon:'fa-paperclip',   color:'bg-secondary', label:'Lampiran'    }
};
%>

<div class="card">
  <div class="card-header pro-head d-flex flex-wrap align-items-center py-3">
    <div class="mr-auto">
      <h3 class="card-title font-weight-bold mb-0" style="font-size:1.15rem;">
        <i class="fas fa-bell mr-2"></i>Semua Notifikasi
      </h3>
      <div class="pro-sub mt-1"><%= notifications.length %> notifikasi</div>
    </div>
    <% if (notifications.length > 0) { %>
    <div class="mt-2 mt-md-0">
      <form action="/notifications/mark-all-read" method="POST" class="d-inline">
        <button type="submit" class="btn btn-light btn-sm shadow-sm">
          <i class="fas fa-check-double mr-1"></i> Tandai Semua Dibaca
        </button>
      </form>
      <form action="/notifications/delete-all" method="POST" class="d-inline ml-1"
            onsubmit="return confirm('Hapus semua notifikasi?')">
        <button type="submit" class="btn btn-outline-light btn-sm shadow-sm">
          <i class="fas fa-trash mr-1"></i> Hapus Semua
        </button>
      </form>
    </div>
    <% } %>
  </div>

  <div class="card-body p-0">
    <% if (notifications.length === 0) { %>
    <div class="text-center text-muted py-5">
      <i class="fas fa-bell-slash fa-3x mb-3 d-block"></i>
      Belum ada notifikasi
    </div>
    <% } else { %>

    <div class="timeline px-3 pt-3">
      <% let lastDate = null; %>
      <% notifications.forEach(n => { %>

      <%
        const ni = nIconMap[n.type] || { icon:'fa-bell', color:'bg-secondary', label:'Info' };
        const nDate = new Date(n.created_at).toLocaleDateString('id-ID', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
      %>

      <% if (nDate !== lastDate) { %>
        <% lastDate = nDate; %>
        <div class="time-label"><span class="bg-secondary"><%= nDate %></span></div>
      <% } %>

      <div>
        <i class="fas <%= ni.icon %> <%= ni.color %>"></i>
        <div class="timeline-item <%= n.is_read ? '' : 'elevation-1' %>" style="<%= n.is_read ? '' : 'border-left: 3px solid #ffc107;' %>">
          <span class="time">
            <i class="fas fa-clock mr-1"></i><%= timeAgo(n.created_at) %>
          </span>
          <h3 class="timeline-header">
            <span class="badge badge-<%= n.type === 'ticket_created' ? 'primary' : n.type === 'ticket_assigned' ? 'warning' : n.type === 'comment_added' ? 'info' : n.type === 'status_changed' ? 'success' : 'secondary' %> mr-1">
              <%= ni.label %>
            </span>
            <% if (!n.is_read) { %>
            <span class="badge badge-warning" style="font-size:0.6rem;">Baru</span>
            <% } %>
          </h3>
          <div class="timeline-body">
            <%- n.message %>
          </div>
          <% if (n.ticket_id) { %>
          <div class="timeline-footer">
            <a href="/tickets/<%= n.ticket_id %>" class="btn btn-xs btn-primary">
              <i class="fas fa-eye mr-1"></i>Lihat Tiket
              <% if (n.ticket_number) { %><code class="ml-1 text-light"><%= n.ticket_number %></code><% } %>
            </a>
          </div>
          <% } %>
        </div>
      </div>

      <% }) %>

      <div><i class="fas fa-clock bg-gray"></i></div>
    </div>

    <% } %>
  </div>
</div>
