<!-- Stat Boxes -->
<div class="row">
  <div class="col-lg-3 col-6">
    <div class="small-box bg-gradient-info">
      <div class="inner">
        <h3><%= stats.total %></h3>
        <p>Total Tiket</p>
      </div>
      <div class="icon"><i class="fas fa-ticket-alt"></i></div>
      <a href="/tickets" class="small-box-footer">Lihat Semua <i class="fas fa-arrow-circle-right"></i></a>
    </div>
  </div>
  <div class="col-lg-3 col-6">
    <div class="small-box bg-gradient-warning">
      <div class="inner">
        <h3><%= stats.open %></h3>
        <p><%= user.role === 'technician' ? 'Tiket Diterima' : 'Tiket Baru' %></p>
      </div>
      <div class="icon"><i class="fas fa-envelope-open-text"></i></div>
      <a href="/tickets?status=<%= user.role === 'technician' ? 'assigned' : 'open' %>" class="small-box-footer">Lihat Detail <i class="fas fa-arrow-circle-right"></i></a>
    </div>
  </div>
  <div class="col-lg-3 col-6">
    <div class="small-box bg-gradient-primary">
      <div class="inner">
        <h3><%= stats.in_progress %></h3>
        <p>Sedang Dikerjakan</p>
      </div>
      <div class="icon"><i class="fas fa-tools"></i></div>
      <a href="/tickets?status=in_progress" class="small-box-footer">Lihat Detail <i class="fas fa-arrow-circle-right"></i></a>
    </div>
  </div>
  <div class="col-lg-3 col-6">
    <div class="small-box bg-gradient-success">
      <div class="inner">
        <h3><%= stats.resolved %></h3>
        <p>Terselesaikan</p>
      </div>
      <div class="icon"><i class="fas fa-check-double"></i></div>
      <a href="/tickets?status=resolved" class="small-box-footer">Lihat Detail <i class="fas fa-arrow-circle-right"></i></a>
    </div>
  </div>
</div>

<!-- Recent Tickets -->
<div class="card shadow-sm">
  <div class="card-header border-0">
    <h3 class="card-title font-weight-bold">
      <i class="fas fa-list-alt text-primary mr-2"></i>Tiket Terbaru
    </h3>
    <div class="card-tools">
      <a href="/tickets" class="btn btn-sm btn-outline-primary">
        <i class="fas fa-external-link-alt mr-1"></i> Lihat Semua
      </a>
    </div>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="thead-light">
          <tr>
            <th>No. Tiket</th>
            <th>Judul</th>
            <th>Kategori</th>
            <th>Prioritas</th>
            <th>Status</th>
            <% if (user.role !== 'reporter') { %><th>Pembuat</th><% } %>
            <% if (user.role !== 'technician') { %><th>Teknisi</th><% } %>
            <th>Tanggal</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% if (recentTickets.length === 0) { %>
          <tr>
            <td colspan="8" class="text-center text-muted py-4">
              <i class="fas fa-inbox fa-2x mb-2 d-block"></i> Belum ada tiket
            </td>
          </tr>
          <% } %>
          <% recentTickets.forEach(ticket => { %>
          <tr>
            <td><code class="text-primary"><%= ticket.ticket_number %></code></td>
            <td><%= ticket.title.length > 40 ? ticket.title.substring(0,40)+'...' : ticket.title %></td>
            <td><small class="badge badge-light border"><%= ticket.category %></small></td>
            <td>
              <% const pClass = {low:'success',medium:'warning',high:'orange',critical:'danger'}; %>
              <span class="badge badge-<%= ticket.priority === 'high' ? 'warning' : ticket.priority === 'critical' ? 'danger' : ticket.priority === 'medium' ? 'info' : 'secondary' %>">
                <%= ticket.priority.toUpperCase() %>
              </span>
            </td>
            <td>
              <% const sClass = {open:'secondary',assigned:'info',in_progress:'primary',resolved:'success',closed:'dark'}; %>
              <span class="badge badge-<%= sClass[ticket.status] || 'secondary' %>">
                <%= ticket.status.replace('_',' ').toUpperCase() %>
              </span>
            </td>
            <% if (user.role !== 'reporter') { %><td><%= ticket.creator_name %></td><% } %>
            <% if (user.role !== 'technician') { %><td><% if (ticket.assignee_name) { %><%= ticket.assignee_name %><% } else { %><span class="text-muted">-</span><% } %></td><% } %>
            <td><small><%= new Date(ticket.created_at).toLocaleDateString('id-ID') %></small></td>
            <td>
              <a href="/tickets/<%= ticket.id %>" class="btn btn-xs btn-info">
                <i class="fas fa-eye"></i>
              </a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
