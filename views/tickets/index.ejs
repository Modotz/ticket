<div class="card shadow-sm">
  <div class="card-header border-0">
    <h3 class="card-title font-weight-bold">
      <i class="fas fa-ticket-alt text-primary mr-2"></i>Daftar Tiket
    </h3>
    <div class="card-tools">
      <% if (user.role === 'admin' || user.role === 'reporter' || user.role === 'supervisor') { %>
      <a href="/tickets/create" class="btn btn-primary btn-sm">
        <i class="fas fa-plus mr-1"></i> Buat Tiket
      </a>
      <% } %>
    </div>
  </div>

  <!-- Filter -->
  <div class="card-body border-bottom pb-3">
    <form method="GET" action="/tickets">
      <div class="row align-items-end">
        <div class="col-md-3 mb-2">
          <label class="small text-muted mb-1">Status</label>
          <select name="status" class="form-control form-control-sm">
            <option value="">Semua Status</option>
            <% ['open','assigned','in_progress','resolved','closed'].forEach(s => { %>
            <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s.replace('_',' ').toUpperCase() %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-2 mb-2">
          <label class="small text-muted mb-1">Prioritas</label>
          <select name="priority" class="form-control form-control-sm">
            <option value="">Semua</option>
            <% ['low','medium','high','critical'].forEach(p => { %>
            <option value="<%= p %>" <%= filters.priority === p ? 'selected' : '' %>><%= p.toUpperCase() %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-4 mb-2">
          <label class="small text-muted mb-1">Cari</label>
          <input type="text" name="search" class="form-control form-control-sm"
                 placeholder="Judul atau nomor tiket..." value="<%= filters.search || '' %>">
        </div>
        <div class="col-md-2 mb-2">
          <button type="submit" class="btn btn-secondary btn-sm btn-block">
            <i class="fas fa-search mr-1"></i> Filter
          </button>
        </div>
        <div class="col-md-1 mb-2">
          <a href="/tickets" class="btn btn-light btn-sm btn-block" title="Reset">
            <i class="fas fa-redo"></i>
          </a>
        </div>
      </div>
    </form>
  </div>

  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover table-bordered mb-0">
        <thead class="thead-light">
          <tr>
            <th width="150">No. Tiket</th>
            <th>Judul</th>
            <th width="130">Kategori</th>
            <th width="100">Prioritas</th>
            <th width="120">Status</th>
            <th width="120">Pembuat</th>
            <th width="120">Teknisi</th>
            <th width="100">Tanggal</th>
            <th width="100">Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (tickets.length === 0) { %>
          <tr>
            <td colspan="9" class="text-center text-muted py-5">
              <i class="fas fa-search fa-2x mb-2 d-block"></i>
              Tidak ada tiket ditemukan
            </td>
          </tr>
          <% } %>
          <% tickets.forEach(ticket => { %>
          <tr>
            <td><code class="text-primary"><%= ticket.ticket_number %></code></td>
            <td>
              <a href="/tickets/<%= ticket.id %>" class="text-dark font-weight-bold">
                <%= ticket.title.length > 50 ? ticket.title.substring(0,50)+'...' : ticket.title %>
              </a>
            </td>
            <td><small class="badge badge-light border"><%= ticket.category %></small></td>
            <td>
              <span class="badge badge-<%= ticket.priority === 'critical' ? 'danger' : ticket.priority === 'high' ? 'warning' : ticket.priority === 'medium' ? 'info' : 'secondary' %>">
                <%= ticket.priority.toUpperCase() %>
              </span>
            </td>
            <td>
              <% const sClass = {open:'secondary',assigned:'info',in_progress:'primary',resolved:'success',closed:'dark'}; %>
              <span class="badge badge-<%= sClass[ticket.status] || 'secondary' %>">
                <%= ticket.status.replace('_',' ').toUpperCase() %>
              </span>
            </td>
            <td><small><%= ticket.creator_name %></small></td>
            <td><small><% if (ticket.assignee_name) { %><%= ticket.assignee_name %><% } else { %><span class="text-muted">-</span><% } %></small></td>
            <td><small><%= new Date(ticket.created_at).toLocaleDateString('id-ID') %></small></td>
            <td>
              <a href="/tickets/<%= ticket.id %>" class="btn btn-xs btn-info" title="Detail">
                <i class="fas fa-eye"></i>
              </a>
              <% if (user.role === 'admin') { %>
              <a href="/tickets/<%= ticket.id %>/edit" class="btn btn-xs btn-warning" title="Edit">
                <i class="fas fa-edit"></i>
              </a>
              <form action="/tickets/<%= ticket.id %>?_method=DELETE" method="POST" class="d-inline"
                    onsubmit="return confirm('Hapus tiket <%= ticket.ticket_number %>?')">
                <button type="submit" class="btn btn-xs btn-danger" title="Hapus">
                  <i class="fas fa-trash"></i>
                </button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="card-footer text-muted small">
      Total: <strong><%= tickets.length %></strong> tiket
    </div>
  </div>
</div>
