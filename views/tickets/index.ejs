<%
  const pMap = {
    low:      { c: 'success',   i: 'fa-angle-down',   t: 'Low' },
    medium:   { c: 'info',      i: 'fa-equals',       t: 'Medium' },
    high:     { c: 'warning',   i: 'fa-angle-up',     t: 'High' },
    critical: { c: 'danger',    i: 'fa-fire',         t: 'Critical' }
  };
  const sMap = {
    open:        { c: 'secondary', t: 'Open' },
    assigned:    { c: 'info',      t: 'Assigned' },
    in_progress: { c: 'primary',   t: 'In Progress' },
    resolved:    { c: 'success',   t: 'Resolved' },
    closed:      { c: 'dark',      t: 'Closed' }
  };
  const ef = {};
  ['status','priority','search','date_from','date_to'].forEach(k => { if (filters[k]) ef[k] = filters[k]; });
  const exportQS = new URLSearchParams(ef).toString();
  const hasFilter = Object.keys(ef).length > 0;

  // Helper URL pagination: pertahankan semua filter yang aktif.
  const pageUrl = (n) => {
    const p = new URLSearchParams(ef);
    p.set('page', n);
    return '/tickets?' + p.toString();
  };
  const pag = typeof pagination !== 'undefined' ? pagination
              : { page:1, totalPages:1, total: tickets.length, perPage: tickets.length, offset:0 };
  const showFrom = pag.total === 0 ? 0 : pag.offset + 1;
  const showTo   = Math.min(pag.offset + tickets.length, pag.total);

  // Daftar nomor halaman (jendela ±2 di sekitar halaman aktif)
  function pageWindow(cur, last) {
    const set = new Set([1, last, cur, cur-1, cur-2, cur+1, cur+2]);
    return [...set].filter(n => n >= 1 && n <= last).sort((a,b)=>a-b);
  }
  const windowPages = pageWindow(pag.page, pag.totalPages);
%>

<style>
  .tkt-card { border: 0; border-radius: .6rem; overflow: hidden; }
  .tkt-head { background: linear-gradient(135deg,#2f5597,#1f3a6b); color:#fff; }
  .tkt-head .tkt-sub { color: rgba(255,255,255,.75); font-size: .8rem; }
  .tkt-filter { background:#f8fafc; }
  .tkt-filter label { font-size:.72rem; text-transform:uppercase; letter-spacing:.04em;
                      color:#8392a5; font-weight:600; margin-bottom:.25rem; }
  .tbl-tkt { margin-bottom:0; }
  .tbl-tkt thead th { font-size:.7rem; letter-spacing:.05em; text-transform:uppercase;
                      color:#6c757d; background:#f1f4f8; border-top:0;
                      border-bottom:2px solid #e3e8ef; white-space:nowrap; }
  .tbl-tkt td, .tbl-tkt th { vertical-align:middle; }
  .tbl-tkt tbody tr { transition:background .12s; }
  .tbl-tkt tbody tr:hover { background:#f4f9ff; }
  .tkt-no { font-family:SFMono-Regular,Menlo,Consolas,monospace; font-size:.78rem;
            font-weight:600; color:#2f5597; text-decoration:none; }
  .tkt-no:hover { text-decoration:underline; }
  .tkt-title { color:#1f2d3d; font-weight:600; }
  .tkt-title:hover { color:#2f5597; }
  .badge-soft { font-weight:600; font-size:.7rem; padding:.35em .6em; border-radius:50rem; }
  .badge-dot { width:7px; height:7px; border-radius:50%; display:inline-block; margin-right:5px; }
  .avatar-xs { width:24px; height:24px; border-radius:50%; object-fit:cover;
               margin-right:6px; vertical-align:middle; }
  .act-group .btn { padding:.2rem .45rem; }
  .filter-chip { background:#e9f2ff; color:#2f5597; border-radius:50rem;
                 font-size:.72rem; padding:.2rem .6rem; margin-right:.35rem; }
  .sla-bar { height:7px; background:#e9ecef; border-radius:50rem; overflow:hidden; margin:3px 0; }
  .sla-bar-fill { height:100%; border-radius:50rem; transition:width .4s ease; }
</style>

<div class="card tkt-card shadow-sm">

  <!-- Header -->
  <div class="card-header tkt-head d-flex flex-wrap align-items-center py-3">
    <div class="mr-auto">
      <h3 class="card-title font-weight-bold mb-0" style="font-size:1.15rem;">
        <i class="fas fa-ticket-alt mr-2"></i>Daftar Tiket
      </h3>
      <div class="tkt-sub mt-1">
        <%= tickets.length %> tiket<% if (hasFilter) { %> · hasil terfilter<% } %>
      </div>
    </div>
    <div class="mt-2 mt-md-0">
      <a href="/tickets/export<%= exportQS ? '?' + exportQS : '' %>"
         class="btn btn-success btn-sm shadow-sm <%= tickets.length === 0 ? 'disabled' : '' %>">
        <i class="fas fa-file-excel mr-1"></i> Export Excel
      </a>
      <% if (user.role === 'admin' || user.role === 'reporter' || user.role === 'supervisor') { %>
      <a href="/tickets/create" class="btn btn-light btn-sm shadow-sm ml-1">
        <i class="fas fa-plus mr-1"></i> Buat Tiket
      </a>
      <% } %>
    </div>
  </div>

  <!-- Filter -->
  <div class="card-body tkt-filter border-bottom py-3">
    <form method="GET" action="/tickets">
      <div class="form-row align-items-end">
        <div class="col-md-2 mb-2">
          <label>Status</label>
          <select name="status" class="form-control form-control-sm">
            <option value="">Semua</option>
            <% Object.keys(sMap).forEach(s => { %>
            <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= sMap[s].t %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-2 mb-2">
          <label>Prioritas</label>
          <select name="priority" class="form-control form-control-sm">
            <option value="">Semua</option>
            <% Object.keys(pMap).forEach(p => { %>
            <option value="<%= p %>" <%= filters.priority === p ? 'selected' : '' %>><%= pMap[p].t %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-2 mb-2">
          <label>Dari Tanggal <span class="text-muted" style="text-transform:none;">(opsional)</span></label>
          <input type="date" name="date_from" class="form-control form-control-sm"
                 value="<%= filters.date_from || '' %>">
        </div>
        <div class="col-md-2 mb-2">
          <label>Sampai Tanggal <span class="text-muted" style="text-transform:none;">(opsional)</span></label>
          <input type="date" name="date_to" class="form-control form-control-sm"
                 value="<%= filters.date_to || '' %>">
        </div>
        <div class="col-md-2 mb-2">
          <label>Cari</label>
          <input type="text" name="search" class="form-control form-control-sm"
                 placeholder="Judul / no. tiket" value="<%= filters.search || '' %>">
        </div>
        <div class="col-md-2 mb-2">
          <div class="btn-group btn-block" role="group">
            <button type="submit" class="btn btn-primary btn-sm">
              <i class="fas fa-filter mr-1"></i> Filter
            </button>
            <a href="/tickets" class="btn btn-outline-secondary btn-sm" title="Reset filter">
              <i class="fas fa-redo"></i>
            </a>
          </div>
        </div>
      </div>
      <% if (hasFilter) { %>
      <div class="mt-1">
        <% if (filters.status)   { %><span class="filter-chip">Status: <%= sMap[filters.status] ? sMap[filters.status].t : filters.status %></span><% } %>
        <% if (filters.priority) { %><span class="filter-chip">Prioritas: <%= pMap[filters.priority] ? pMap[filters.priority].t : filters.priority %></span><% } %>
        <% if (filters.date_from){ %><span class="filter-chip">Dari: <%= filters.date_from %></span><% } %>
        <% if (filters.date_to)  { %><span class="filter-chip">Sampai: <%= filters.date_to %></span><% } %>
        <% if (filters.search)   { %><span class="filter-chip">Cari: "<%= filters.search %>"</span><% } %>
      </div>
      <% } %>
    </form>
  </div>

  <!-- Tabel -->
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table tbl-tkt">
        <thead>
          <tr>
            <th style="width:160px;">No. Tiket</th>
            <th>Judul</th>
            <th style="width:140px;">Kategori</th>
            <th style="width:120px;">Prioritas</th>
            <th style="width:130px;">Status</th>
            <th style="width:170px;">Progres SLA</th>
            <th style="width:150px;">Pembuat</th>
            <th style="width:150px;">Teknisi</th>
            <th style="width:110px;">Tanggal</th>
            <th style="width:120px;" class="text-center">Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (tickets.length === 0) { %>
          <tr>
            <td colspan="10" class="text-center text-muted py-5">
              <i class="fas fa-inbox fa-3x mb-3 d-block text-light"></i>
              <span class="font-weight-bold">Tidak ada tiket ditemukan</span><br>
              <small><% if (hasFilter) { %>Coba ubah atau reset filter di atas.<% } else { %>Belum ada tiket yang dibuat.<% } %></small>
            </td>
          </tr>
          <% } %>
          <% tickets.forEach(ticket => {
               const p = pMap[ticket.priority] || { c:'secondary', i:'fa-circle', t:ticket.priority };
               const s = sMap[ticket.status]   || { c:'secondary', t:ticket.status };
          %>
          <tr>
            <td>
              <a href="/tickets/<%= ticket.id %>" class="tkt-no"><%= ticket.ticket_number %></a>
            </td>
            <td>
              <a href="/tickets/<%= ticket.id %>" class="tkt-title d-block text-truncate"
                 style="max-width:340px;" title="<%= ticket.title %>">
                <%= ticket.title %>
              </a>
            </td>
            <td>
              <span class="badge badge-light border text-muted"><%= ticket.category %></span>
            </td>
            <td>
              <span class="badge badge-soft badge-<%= p.c %>">
                <i class="fas <%= p.i %> mr-1"></i><%= p.t.toUpperCase() %>
              </span>
            </td>
            <td>
              <span class="badge badge-soft badge-<%= s.c %>">
                <span class="badge-dot bg-light"></span><%= s.t.toUpperCase() %>
              </span>
            </td>
            <td>
              <% const sla = ticket.sla || { state:'none' }; %>
              <% if (sla.state === 'none') { %>
              <small class="text-muted"><i class="fas fa-minus-circle mr-1"></i>SLA belum diatur</small>
              <% } else { %>
              <div class="sla-wrap">
                <div class="d-flex justify-content-between align-items-center" style="font-size:.68rem;">
                  <span class="text-muted">Target: <%= sla.target %></span>
                  <span class="font-weight-bold text-<%= sla.color %>"><%= sla.pct %>%</span>
                </div>
                <div class="sla-bar">
                  <div class="sla-bar-fill bg-<%= sla.color %>" style="width:<%= sla.pct %>%;"></div>
                </div>
                <small class="text-<%= sla.color %>" style="font-size:.66rem;">
                  <i class="fas <%= sla.state==='breach'||sla.state==='done_late' ? 'fa-exclamation-triangle' : sla.state==='done_ok' ? 'fa-check-circle' : 'fa-clock' %> mr-1"></i><%= sla.label %>
                </small>
              </div>
              <% } %>
            </td>
            <td class="text-truncate" style="max-width:150px;">
              <img class="avatar-xs"
                   src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(ticket.creator_name || '?') %>&size=24&background=2f5597&color=fff"
                   alt="">
              <small><%= ticket.creator_name || '-' %></small>
            </td>
            <td class="text-truncate" style="max-width:150px;">
              <% if (ticket.assignee_name) { %>
              <img class="avatar-xs"
                   src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(ticket.assignee_name) %>&size=24&background=6c757d&color=fff"
                   alt="">
              <small><%= ticket.assignee_name %></small>
              <% } else { %>
              <small class="text-muted"><i class="fas fa-user-slash mr-1"></i>Belum ada</small>
              <% } %>
            </td>
            <td>
              <small class="d-block"><%= new Date(ticket.created_at).toLocaleDateString('id-ID') %></small>
              <small class="text-muted" style="font-size:.68rem;"><%= timeAgo(ticket.created_at) %></small>
            </td>
            <td class="text-center">
              <div class="btn-group act-group" role="group">
                <a href="/tickets/<%= ticket.id %>" class="btn btn-sm btn-outline-info" title="Detail">
                  <i class="fas fa-eye"></i>
                </a>
                <% if (user.role === 'admin') { %>
                <a href="/tickets/<%= ticket.id %>/edit" class="btn btn-sm btn-outline-warning" title="Edit">
                  <i class="fas fa-edit"></i>
                </a>
                <form action="/tickets/<%= ticket.id %>?_method=DELETE" method="POST" class="d-inline"
                      onsubmit="return confirm('Hapus tiket <%= ticket.ticket_number %>? Tindakan ini tidak dapat dibatalkan.')">
                  <button type="submit" class="btn btn-sm btn-outline-danger" title="Hapus">
                    <i class="fas fa-trash"></i>
                  </button>
                </form>
                <% } %>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="card-footer bg-white">
      <div class="d-flex flex-wrap justify-content-between align-items-center text-muted small mb-2">
        <span>
          Menampilkan
          <strong class="text-dark"><%= showFrom %></strong>–<strong class="text-dark"><%= showTo %></strong>
          dari <strong class="text-dark"><%= pag.total %></strong> tiket
          <% if (pag.totalPages > 1) { %> · Halaman <strong class="text-dark"><%= pag.page %></strong>/<%= pag.totalPages %><% } %>
        </span>
        <% if (pag.total > 0) { %>
        <a href="/tickets/export<%= exportQS ? '?' + exportQS : '' %>" class="text-success">
          <i class="fas fa-download mr-1"></i>Unduh <%= hasFilter ? 'hasil filter' : 'semua' %> sebagai Excel
        </a>
        <% } %>
      </div>

      <% if (pag.totalPages > 1) { %>
      <nav>
        <ul class="pagination pagination-sm mb-0 justify-content-end">
          <li class="page-item <%= pag.page <= 1 ? 'disabled' : '' %>">
            <a class="page-link" href="<%= pageUrl(pag.page - 1) %>" aria-label="Sebelumnya">
              <i class="fas fa-chevron-left"></i>
            </a>
          </li>
          <% let prev = 0; %>
          <% windowPages.forEach(n => { %>
            <% if (n - prev > 1) { %>
            <li class="page-item disabled"><span class="page-link">…</span></li>
            <% } %>
            <li class="page-item <%= n === pag.page ? 'active' : '' %>">
              <a class="page-link" href="<%= pageUrl(n) %>"><%= n %></a>
            </li>
            <% prev = n; %>
          <% }) %>
          <li class="page-item <%= pag.page >= pag.totalPages ? 'disabled' : '' %>">
            <a class="page-link" href="<%= pageUrl(pag.page + 1) %>" aria-label="Berikutnya">
              <i class="fas fa-chevron-right"></i>
            </a>
          </li>
        </ul>
      </nav>
      <% } %>
    </div>
  </div>
</div>
