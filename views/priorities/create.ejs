<div class="row justify-content-center">
  <div class="col-md-7">
    <div class="card shadow">
      <div class="card-header pro-head py-3">
        <h3 class="card-title"><i class="fas fa-plus mr-2"></i>Tambah Prioritas</h3>
      </div>
      <form action="/priorities" method="POST">
        <div class="card-body">
          <div class="row">
            <div class="col-md-6 form-group">
              <label class="font-weight-bold">Kode <span class="text-danger">*</span></label>
              <input type="text" name="code" class="form-control" maxlength="30"
                     placeholder="mis. urgent" required>
              <small class="text-muted">Huruf kecil tanpa spasi (otomatis dirapikan). Unik.</small>
            </div>
            <div class="col-md-6 form-group">
              <label class="font-weight-bold">Nama Tampil <span class="text-danger">*</span></label>
              <input type="text" name="name" class="form-control" maxlength="40"
                     placeholder="mis. Urgent" required>
            </div>
          </div>
          <div class="row">
            <div class="col-md-4 form-group">
              <label class="font-weight-bold">Warna Badge</label>
              <select name="color" class="form-control">
                <% COLORS.forEach(c => { %>
                <option value="<%= c %>" <%= c === 'secondary' ? 'selected' : '' %>><%= c %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-5 form-group">
              <label class="font-weight-bold">Waktu (SLA) <span class="text-danger">*</span></label>
              <div class="input-group">
                <input type="number" name="duration_value" class="form-control" min="1" value="1" required>
                <div class="input-group-append">
                  <select name="duration_unit" class="form-control">
                    <% UNITS.forEach(u => { %>
                    <option value="<%= u %>" <%= u === 'hari' ? 'selected' : '' %>><%= u %></option>
                    <% }) %>
                  </select>
                </div>
              </div>
              <small class="text-muted">Target waktu penyelesaian. Contoh: 2 hari / 1 minggu.</small>
            </div>
            <div class="col-md-3 form-group">
              <label class="font-weight-bold">Urutan</label>
              <input type="number" name="sort_order" class="form-control" value="0">
              <small class="text-muted">Urutan tampil di dropdown.</small>
            </div>
          </div>
        </div>
        <div class="card-footer d-flex justify-content-between align-items-center">
          <a href="/priorities" class="btn btn-secondary">
            <i class="fas fa-arrow-left mr-1"></i> Kembali
          </a>
          <button type="submit" class="btn btn-primary ml-auto">
            <i class="fas fa-save mr-1"></i> Simpan
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
