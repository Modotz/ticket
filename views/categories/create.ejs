<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow">
      <div class="card-header pro-head py-3">
        <h3 class="card-title"><i class="fas fa-plus mr-2"></i>Tambah Kategori</h3>
      </div>
      <form action="/categories" method="POST">
        <div class="card-body">
          <div class="form-group mb-0">
            <label class="font-weight-bold">Nama Kategori <span class="text-danger">*</span></label>
            <input type="text" name="name" class="form-control" maxlength="60"
                   placeholder="Contoh: Hardware" required autofocus>
            <small class="text-muted">Nama harus unik. Akan tampil di form pembuatan tiket.</small>
          </div>
        </div>
        <div class="card-footer d-flex justify-content-between align-items-center">
          <a href="/categories" class="btn btn-secondary">
            <i class="fas fa-arrow-left mr-1"></i> Kembali
          </a>
          <button type="submit" class="btn btn-primary ml-auto">
            <i class="fas fa-save mr-1"></i> Simpan
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
