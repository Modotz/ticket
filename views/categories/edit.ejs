<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow">
      <div class="card-header pro-head py-3">
        <h3 class="card-title"><i class="fas fa-edit mr-2"></i>Edit Kategori</h3>
      </div>
      <form action="/categories/<%= category.id %>?_method=PUT" method="POST">
        <div class="card-body">
          <div class="form-group">
            <label class="font-weight-bold">Nama Kategori <span class="text-danger">*</span></label>
            <input type="text" name="name" class="form-control" maxlength="60"
                   value="<%= category.name %>" required autofocus>
            <small class="text-muted">Mengubah nama akan ikut memperbarui tiket lama yang memakainya.</small>
          </div>
          <div class="form-group mb-0">
            <div class="custom-control custom-switch">
              <input type="checkbox" class="custom-control-input" id="is_active" name="is_active"
                     value="1" <%= category.is_active ? 'checked' : '' %>>
              <label class="custom-control-label font-weight-bold" for="is_active">Aktif</label>
            </div>
            <small class="text-muted">Nonaktif = tetap di tiket lama, tapi tidak bisa dipilih di tiket baru.</small>
          </div>
        </div>
        <div class="card-footer d-flex justify-content-between align-items-center">
          <a href="/categories" class="btn btn-secondary">
            <i class="fas fa-arrow-left mr-1"></i> Kembali
          </a>
          <button type="submit" class="btn btn-primary ml-auto">
            <i class="fas fa-save mr-1"></i> Simpan Perubahan
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
