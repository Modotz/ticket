<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card shadow">
      <div class="card-header pro-head py-3">
        <h3 class="card-title"><i class="fas fa-key mr-2"></i>Ganti Password</h3>
      </div>
      <form action="/auth/change-password" method="POST">
        <div class="card-body">

          <div class="alert alert-info py-2 small">
            <i class="fas fa-info-circle mr-1"></i>
            Setelah ganti password, Anda akan otomatis logout dan diminta login ulang.
          </div>

          <div class="form-group">
            <label class="font-weight-bold">Password Saat Ini <span class="text-danger">*</span></label>
            <div class="input-group">
              <input type="password" name="current_password" id="cur_pwd"
                     class="form-control" placeholder="Masukkan password saat ini" required>
              <div class="input-group-append">
                <button type="button" class="btn btn-outline-secondary" onclick="togglePwd('cur_pwd', this)">
                  <i class="fas fa-eye"></i>
                </button>
              </div>
            </div>
          </div>

          <div class="form-group">
            <label class="font-weight-bold">Password Baru <span class="text-danger">*</span></label>
            <div class="input-group">
              <input type="password" name="new_password" id="new_pwd"
                     class="form-control" placeholder="Minimal 6 karakter"
                     required minlength="6" oninput="checkStrength(this.value)">
              <div class="input-group-append">
                <button type="button" class="btn btn-outline-secondary" onclick="togglePwd('new_pwd', this)">
                  <i class="fas fa-eye"></i>
                </button>
              </div>
            </div>
            <!-- Password strength bar -->
            <div class="mt-1" id="strength-wrap" style="display:none;">
              <div class="progress" style="height:5px;">
                <div id="strength-bar" class="progress-bar" style="width:0%;transition:width .3s;"></div>
              </div>
              <small id="strength-label" class="text-muted"></small>
            </div>
          </div>

          <div class="form-group">
            <label class="font-weight-bold">Konfirmasi Password Baru <span class="text-danger">*</span></label>
            <div class="input-group">
              <input type="password" name="confirm_password" id="con_pwd"
                     class="form-control" placeholder="Ulangi password baru"
                     required oninput="checkMatch()">
              <div class="input-group-append">
                <button type="button" class="btn btn-outline-secondary" onclick="togglePwd('con_pwd', this)">
                  <i class="fas fa-eye"></i>
                </button>
              </div>
            </div>
            <small id="match-msg" style="display:none;"></small>
          </div>

        </div>
        <div class="card-footer d-flex justify-content-between">
          <button type="submit" class="btn btn-primary" id="submit-btn">
            <i class="fas fa-save mr-1"></i> Simpan Password Baru
          </button>
          <a href="/" class="btn btn-secondary">
            <i class="fas fa-times mr-1"></i> Batal
          </a>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function togglePwd(id, btn) {
  const inp = document.getElementById(id);
  const isText = inp.type === 'text';
  inp.type = isText ? 'password' : 'text';
  btn.querySelector('i').className = 'fas fa-eye' + (isText ? '' : '-slash');
}

function checkStrength(val) {
  const wrap  = document.getElementById('strength-wrap');
  const bar   = document.getElementById('strength-bar');
  const label = document.getElementById('strength-label');
  if (!val) { wrap.style.display = 'none'; return; }
  wrap.style.display = '';

  let score = 0;
  if (val.length >= 6)  score++;
  if (val.length >= 10) score++;
  if (/[A-Z]/.test(val)) score++;
  if (/[0-9]/.test(val)) score++;
  if (/[^A-Za-z0-9]/.test(val)) score++;

  const levels = [
    { pct:'20%', cls:'bg-danger',  txt:'Sangat Lemah' },
    { pct:'40%', cls:'bg-warning', txt:'Lemah'        },
    { pct:'60%', cls:'bg-info',    txt:'Cukup'        },
    { pct:'80%', cls:'bg-primary', txt:'Kuat'         },
    { pct:'100%',cls:'bg-success', txt:'Sangat Kuat'  },
  ];
  const lv = levels[Math.min(score, 4)];
  bar.style.width = lv.pct;
  bar.className   = 'progress-bar ' + lv.cls;
  label.textContent = lv.txt;
  label.className   = lv.cls.replace('bg-', 'text-');
}

function checkMatch() {
  const np  = document.getElementById('new_pwd').value;
  const cp  = document.getElementById('con_pwd').value;
  const msg = document.getElementById('match-msg');
  const btn = document.getElementById('submit-btn');
  if (!cp) { msg.style.display = 'none'; return; }
  msg.style.display = '';
  if (np === cp) {
    msg.textContent = '✓ Password cocok';
    msg.className   = 'text-success small';
    btn.disabled    = false;
  } else {
    msg.textContent = '✗ Password tidak cocok';
    msg.className   = 'text-danger small';
    btn.disabled    = true;
  }
}
</script>
