<style>
  .login-page{ min-height:100vh; }
  .login-box{ width:400px; margin:0 auto; }
  .login-card{ border:0; border-radius:.75rem; overflow:hidden;
               box-shadow:0 12px 40px rgba(0,0,0,.35); }
  .login-brand{ background:linear-gradient(135deg,#2f5597,#1f3a6b);
                color:#fff; text-align:center; padding:28px 20px 22px; }
  .login-brand .ic{ width:60px;height:60px;line-height:60px;border-radius:50%;
                    background:rgba(255,255,255,.12); display:inline-block;
                    font-size:26px; margin-bottom:10px; }
  .login-brand h1{ font-size:1.35rem; font-weight:700; margin:0; }
  .login-brand p{ margin:.25rem 0 0; font-size:.82rem; color:rgba(255,255,255,.75); }
  .login-body{ padding:26px 30px 30px; }
  .login-body .input-group-text{ background:#f1f4f8; border-right:0; color:#6c757d; }
  .login-body .form-control{ border-left:0; }
  .login-body .form-control:focus{ border-color:#7ea3d6;
                box-shadow:0 0 0 .2rem rgba(47,85,151,.15); }
  .btn-login{ background:linear-gradient(135deg,#2f5597,#1f3a6b); border:0;
              font-weight:600; letter-spacing:.02em; }
  .btn-login:hover{ filter:brightness(1.08); }
</style>

<div class="login-box">
  <div class="card login-card">
    <div class="login-brand">
      <span class="ic"><i class="fas fa-ticket-alt"></i></span>
      <h1>Ticket TSJ</h1>
      <p>Sistem Tiket Maintenance</p>
    </div>
    <div class="login-body">
      <% if (error && error.length > 0) { %>
      <div class="alert alert-danger alert-dismissible mb-3">
        <button type="button" class="close" data-dismiss="alert">&times;</button>
        <i class="fas fa-exclamation-circle mr-1"></i><%= error[0] %>
      </div>
      <% } %>

      <form action="/auth/login" method="POST">
        <div class="form-group mb-3">
          <label class="font-weight-bold small text-muted">USERNAME</label>
          <div class="input-group">
            <div class="input-group-prepend">
              <span class="input-group-text"><i class="fas fa-user"></i></span>
            </div>
            <input type="text" name="username" class="form-control"
                   placeholder="Masukkan username" autofocus required>
          </div>
        </div>
        <div class="form-group mb-4">
          <label class="font-weight-bold small text-muted">PASSWORD</label>
          <div class="input-group">
            <div class="input-group-prepend">
              <span class="input-group-text"><i class="fas fa-lock"></i></span>
            </div>
            <input type="password" name="password" class="form-control"
                   placeholder="Masukkan password" required>
          </div>
        </div>
        <button type="submit" class="btn btn-login btn-primary btn-block btn-lg">
          <i class="fas fa-sign-in-alt mr-1"></i> Masuk
        </button>
      </form>
    </div>
  </div>
  <p class="text-center mt-3" style="color:rgba(255,255,255,.5);font-size:.78rem;">
    &copy; <%= new Date().getFullYear() %> Ticket Maintenance System
  </p>
</div>
