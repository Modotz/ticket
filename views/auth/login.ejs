<div class="login-box" style="margin:0 auto;">
  <div class="login-logo">
    <a href="#" class="text-white">
      <i class="fas fa-ticket-alt text-warning mr-2"></i>
      <b>Ticket</b> Maintenance
    </a>
  </div>
  <div class="card shadow">
    <div class="card-body login-card-body">
      <p class="login-box-msg text-muted">Masuk ke sistem tiket maintenance</p>

      <% if (error && error.length > 0) { %>
      <div class="alert alert-danger alert-dismissible">
        <button type="button" class="close" data-dismiss="alert">&times;</button>
        <i class="fas fa-exclamation-circle mr-1"></i><%= error[0] %>
      </div>
      <% } %>

      <form action="/auth/login" method="POST">
        <div class="input-group mb-3">
          <input type="text" name="username" class="form-control" placeholder="Username" autofocus required>
          <div class="input-group-append">
            <div class="input-group-text"><i class="fas fa-user"></i></div>
          </div>
        </div>
        <div class="input-group mb-3">
          <input type="password" name="password" class="form-control" placeholder="Password" required>
          <div class="input-group-append">
            <div class="input-group-text"><i class="fas fa-lock"></i></div>
          </div>
        </div>
        <div class="row">
          <div class="col-12">
            <button type="submit" class="btn btn-primary btn-block btn-lg">
              <i class="fas fa-sign-in-alt mr-1"></i> Masuk
            </button>
          </div>
        </div>
      </form>

      <div class="mt-3 p-2 bg-light rounded text-center">
        <small class="text-muted">
          <i class="fas fa-info-circle mr-1"></i>
          Default login: <strong>admin</strong> / <strong>admin123</strong>
        </small>
      </div>
    </div>
  </div>
</div>
