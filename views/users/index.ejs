<div class="card shadow-sm">
  <div class="card-header border-0">
    <h3 class="card-title font-weight-bold">
      <i class="fas fa-users-cog text-primary mr-2"></i>Manajemen Pengguna
    </h3>
    <div class="card-tools">
      <a href="/users/create" class="btn btn-primary btn-sm">
        <i class="fas fa-user-plus mr-1"></i> Tambah Pengguna
      </a>
    </div>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="thead-light">
          <tr>
            <th width="40">#</th>
            <th>Username</th>
            <th>Nama</th>
            <th>Email</th>
            <th width="110">Role</th>
            <th width="90">Status</th>
            <th width="110">Terdaftar</th>
            <th width="100">Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach((u, i) => { %>
          <tr class="<%= !u.is_active ? 'table-secondary' : '' %>">
            <td><%= i + 1 %></td>
            <td>
              <code><%= u.username %></code>
              <% if (u.id === user.id) { %>
              <span class="badge badge-light text-muted ml-1">Anda</span>
              <% } %>
            </td>
            <td><%= u.name %></td>
            <td><small><%= u.email %></small></td>
            <td>
              <span class="badge badge-<%= u.role === 'admin' ? 'danger' : u.role === 'technician' ? 'info' : 'success' %> text-capitalize">
                <%= u.role %>
              </span>
            </td>
            <td>
              <span class="badge badge-<%= u.is_active ? 'success' : 'secondary' %>">
                <%= u.is_active ? 'Aktif' : 'Nonaktif' %>
              </span>
            </td>
            <td><small><%= new Date(u.created_at).toLocaleDateString('id-ID') %></small></td>
            <td>
              <a href="/users/<%= u.id %>/edit" class="btn btn-xs btn-warning" title="Edit">
                <i class="fas fa-edit"></i>
              </a>
              <% if (u.id !== user.id) { %>
              <form action="/users/<%= u.id %>?_method=DELETE" method="POST" class="d-inline"
                    onsubmit="return confirm('Nonaktifkan pengguna <%= u.username %>?')">
                <button type="submit" class="btn btn-xs btn-<%= u.is_active ? 'danger' : 'secondary' %>"
                        title="<%= u.is_active ? 'Nonaktifkan' : 'Sudah Nonaktif' %>">
                  <i class="fas fa-user-slash"></i>
                </button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="card-footer text-muted small">
      Total: <strong><%= users.length %></strong> pengguna
    </div>
  </div>
</div>
