# ── Aplikasi ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3333
APP_URL=http://localhost:3333
SESSION_SECRET=ganti-dengan-string-acak-panjang
# true HANYA jika diakses lewat HTTPS. Untuk http://localhost biarkan false.
COOKIE_SECURE=false
# Password admin awal (hanya dipakai saat akun admin pertama dibuat)
DEFAULT_ADMIN_PASSWORD=admin123

# ── Keamanan login ──────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MIN=15
LOGIN_LOCK_MIN=15

# ── Email (nodemailer / SMTP) ───────────────────────────────────────
MAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Ticket TSJ <no-reply@ticket.local>"

# ── WhatsApp gateway ────────────────────────────────────────────────
# WA_PROVIDER: fonnte | meta | generic
WA_ENABLED=false
WA_PROVIDER=fonnte
WA_API_URL=https://api.fonnte.com/send
WA_TOKEN=
# Khusus provider meta (WhatsApp Cloud API): id nomor pengirim
WA_SENDER=

# ── Telegram (Bot API) ──────────────────────────────────────────────
# Buat bot via @BotFather → dapat TOKEN. User kirim /start ke bot,
# lalu ambil chat_id-nya (mis. via @userinfobot) untuk diisi di profil.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# ── Eskalasi SLA ────────────────────────────────────────────────────
SLA_ESCALATION_ENABLED=true
SLA_CHECK_INTERVAL_MIN=15
